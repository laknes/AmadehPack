# Local PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/amadeh_pack?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/amadeh_pack?schema=public"

# Neon PostgreSQL example
# Use the pooled connection for runtime DATABASE_URL and the direct connection for Prisma schema changes.
# DATABASE_URL="postgresql://USER:PASSWORD@ep-example-pooler.REGION.aws.neon.tech/amadeh_pack?sslmode=require&pgbouncer=true"
# DIRECT_URL="postgresql://USER:PASSWORD@ep-example.REGION.aws.neon.tech/amadeh_pack?sslmode=require"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
UPLOAD_DIR="./public/uploads"

# Payment and trust integrations
PAYMENT_DEFAULT_PROVIDER="MOCK"
ENAMAD_PROFILE_URL="https://enamad.ir"
