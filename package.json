{
  "name": "amadeh-pack-commerce",
  "version": "2.0.0",
  "private": true,
  "description": "Production-ready luxury 3D ecommerce platform for Amadeh Pack.",
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\"",
    "dev": "next dev",
    "dev:clean": "npm run clean && npm run dev",
    "build": "prisma generate && next build",
    "build:clean": "npm run clean && npm run build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fontsource-variable/vazirmatn": "^5.2.8",
    "@fontsource/lalezar": "^5.2.7",
    "@prisma/client": "^6.1.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@tailwindcss/postcss": "^4.1.0",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "framer-motion": "12.23.24",
    "lucide-react": "1.23.0",
    "next": "^15.0.0",
    "next-auth": "^4.24.14",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.15.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^4.1.0",
    "three": "^0.185.1",
    "zod": "^3.24.0",
    "zustand": "^5.0.0"
  },
  "overrides": {
    "motion-dom": "12.23.23"
