# Neon PostgreSQL
# 1. In Neon, copy the pooled connection string into DATABASE_URL.
# 2. Copy the direct connection string into DIRECT_URL.
# 3. Keep sslmode=require. For pooled URLs, keep pgbouncer=true.

DATABASE_URL="postgresql://USER:PASSWORD@ep-example-pooler.REGION.aws.neon.tech/amadeh_pack?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@ep-example.REGION.aws.neon.tech/amadeh_pack?sslmode=require"

NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

UPLOAD_DIR="./public/uploads"

PAYMENT_DEFAULT_PROVIDER="MOCK"
ENAMAD_PROFILE_URL="https://enamad.ir"
